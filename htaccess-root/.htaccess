RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Redirect all traffic on root domain to dashboard subdomain
RewriteCond %{HTTP_HOST} ^(www\.)?etccapps\.com$ [NC]
RewriteCond %{HTTPS} on
RewriteRule ^(.*)$ https://dashboard.etccapps.com/$1 [R=301,L]

# Custom 404
ErrorDocument 404 /apps/dashboard/404.html

# Default charset
AddDefaultCharset UTF-8

# Security headers (requires mod_headers enabled in hPanel)
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-Content-Type-Options "nosniff"
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self';"

# Cache HTML with revalidation
<FilesMatch "\.html$">
  Header set Cache-Control "no-cache, must-revalidate"
</FilesMatch>

# Cache static assets for 30 days
<FilesMatch "\.(png|jpg|jpeg|gif|ico|svg|css|js)$">
  Header set Cache-Control "max-age=2592000, public"
</FilesMatch>
